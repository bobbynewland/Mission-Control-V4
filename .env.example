# =============================================================================
# PLATFORM AUTO-POSTER - API KEYS
# =============================================================================
# Copy this file to .env and fill in your credentials
# 
# SECURITY WARNING: Never commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# YOUTUBE (FUNCTIONAL)
# -----------------------------------------------------------------------------
# YouTube Data API v3 - Full video upload support
#
# Setup:
# 1. Go to https://console.cloud.google.com/
# 2. Create a project (or select existing)
# 3. Enable "YouTube Data API v3"
# 4. Go to Credentials → Create Credentials → OAuth Client ID
# 5. Application type: Web application
# 6. Add authorized redirect URIs (your callback URL)
# 7. Copy Client ID and Client Secret
#
# Getting Refresh Token:
# 1. Use the OAuth flow to authorize your account
# 2. Exchange the authorization code for tokens
# 3. Store the refresh_token securely
#
# Documentation: https://developers.google.com/youtube/v3

YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CHANNEL_ID=  # Optional: Your YouTube channel ID

# -----------------------------------------------------------------------------
# FACEBOOK (FUNCTIONAL)
# -----------------------------------------------------------------------------
# Facebook Graph API - Page posting and Reels
#
# Setup:
# 1. Go to https://developers.facebook.com/
# 2. Create an App → Business type
# 3. Add "Facebook Login" and "Facebook Pages" products
# 4. Configure permissions:
#    - pages_read_engagement
#    - pages_manage_metadata
#    - pages_manage_posts
#    - public_profile (default)
# 5. Go to Graph API Explorer
# 6. Select your Page
# 7. Generate Page Access Token
# 8. Token will need to be extended (expires in ~1 hour by default)
#
# Extend Token:
# GET https://graph.facebook.com/v18.0/oauth/access_token?
#   grant_type=fb_exchange_token&
#   client_id={your-app-id}&
#   client_secret={your-app-secret}&
#   fb_exchange_token={short-lived-token}
#
# Documentation: https://developers.facebook.com/docs/graph-api

FACEBOOK_PAGE_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

# -----------------------------------------------------------------------------
# TIKTOK (NOT AVAILABLE)
# -----------------------------------------------------------------------------
# TikTok Creator API - NOT AVAILABLE for most developers
#
# REALITY: TikTok's API does not support direct video uploads for most accounts.
# Requirements:
# - 100,000+ followers on your TikTok account
# - Special approval from TikTok
# - Business verification
#
# WORKAROUNDS:
# - Buffer API (bufferapp.com) - Third-party posting
# - Publer API (publer.io) - Third-party posting  
# - Later.com - Third-party posting
# - Manual upload reminder to Slack/email
#
# Documentation: https://developers.tiktok.com/products/creator-api/

# TIKTOK_CLIENT_KEY=       # Requires special approval (100k+ followers)
# TIKTOK_CLIENT_SECRET=     # Requires special approval

# -----------------------------------------------------------------------------
# INSTAGRAM (NOT AVAILABLE - REQUIRES FB BUSINESS VERIFICATION)
# -----------------------------------------------------------------------------
# Instagram Graph API - Requires Facebook Business Verification
#
# Setup:
# 1. Complete Facebook Developer account setup
# 2. Create a Facebook App (Business type)
# 3. Add "Instagram" product to your app
# 4. Complete Business Verification:
#    - Submit business documents
#    - Verify domain ownership (if needed)
#    - This can take 1-7 business days
# 5. Connect your Instagram Business or Creator account
# 6. Request these permissions:
#    - instagram_basic
#    - instagram_content_publish
#    - pages_read_engagement
# 7. Generate and store your access token
#
# Documentation: https://developers.facebook.com/docs/instagram-api

INSTAGRAM_ACCOUNT_ID=  # Your Instagram Business Account ID

# -----------------------------------------------------------------------------
# FIREBASE (for platform-poster.js script)
# -----------------------------------------------------------------------------
# These are auto-configured from firebase.js, but can be overridden

# FIREBASE_API_KEY=
